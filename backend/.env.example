# ================================================================
# APP CINCO - CONFIGURACION DE ENTORNO
# ================================================================
#
# IMPORTANTE - SEGURIDAD:
# 1. Copia este archivo a .env antes de iniciar.
# 2. Nunca subas el archivo .env al repositorio.
# 3. Genera una SECRET_KEY unica y segura.
# 4. En produccion, establece DJANGO_DEBUG=False.
#
# ================================================================

# Django
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=False

# Base de datos principal (db_cincosas)
BD_NAME=db_cincosas
BD_USER=db_user
BD_PASSWORD=secure_password_here
BD_HOST=127.0.0.1
BD_PORT=3306

# Base de datos azul (cinco-api)
DB_AZUL_NAME=cinco-api
DB_AZUL_USER=db_user
DB_AZUL_PASSWORD=secure_password_here
DB_AZUL_HOST=127.0.0.1
DB_AZUL_PORT=3306

# Paths (produccion)
BASE_PATH=/home/admcinco/app_cinco/backend/

# Hosts permitidos (separados por coma sin espacios)
ALLOWED_HOSTS=api.cincosas.com,www.api.cincosas.com,192.168.79.11,127.0.0.1,localhost

# IA DEV (orquestador y clasificacion)
IA_DEV_MAX_MESSAGES=100
OPENAI_API_KEY=
IA_DEV_OPENAI_API_KEY=
IA_DEV_USE_OPENAI_CLASSIFIER=1
IA_DEV_INTENT_MODEL=gpt-5-nano
IA_DEV_USE_OPENAI_GENERAL=1
IA_DEV_GENERAL_MODEL=gpt-5-nano
IA_DEV_USE_OPENAI_PERIOD=1
IA_DEV_PERIOD_MODEL=gpt-5-nano
IA_DEV_USE_OPENAI_FOLLOWUPS=1
IA_DEV_FOLLOWUP_MODEL=gpt-5-nano
IA_DEV_DB_ALIAS=default
# Recomendado para este proyecto: tablas ia_dev_* en ai_dictionary (metadata del sistema multiagente).
# Mantiene separacion: metadata/semantica en ai_dictionary y datos operativos en BD de dominio.
IA_DEV_SYSTEM_SCHEMA=ai_dictionary
IA_DEV_ATTENDANCE_TABLE=cincosas_cincosas.gestionh_ausentismo
IA_DEV_DICTIONARY_TABLE=ai_dictionary.dd_dominios
IA_DEV_PERSONAL_TABLE=cincosas_cincosas.cinco_base_de_personal
IA_DEV_USE_DD_TABLAS_MAPPING=1
IA_DEV_TRANSPORT_TABLE=
IA_DEV_TRANSPORT_DATE_COLUMN=fecha_salida
IA_DEV_MAX_PERIOD_DAYS=370

# Gobierno de conocimiento (autoevolucion de reglas)
# ceo = requiere clave, auto = aplica directo, directo = aplica directo
IA_DEV_KNOWLEDGE_GOVERNANCE_MODE=ceo
IA_DEV_CEO_AUTH_KEY=change_this_admin_key

# Cola asincrona de IA DEV
# sync = todo en request, db_queue = encolar y procesar con comando worker
IA_DEV_ASYNC_MODE=sync

# Redis opcional (cache de memoria de sesion)
# Puedes dejar IA_DEV_USE_REDIS=0 hasta que haya mayor carga.
IA_DEV_USE_REDIS=0
IA_DEV_REDIS_URL=redis://127.0.0.1:6379/0
IA_DEV_REDIS_PREFIX=ia_dev
IA_DEV_REDIS_TTL_SECONDS=1800

# Memoria gobernada en runtime de chat
IA_DEV_MEMORY_READ_ENABLED=1
IA_DEV_MEMORY_WRITE_ENABLED=1
IA_DEV_MEMORY_PROPOSALS_ENABLED=1

# Routing capability-first (rollout incremental)
IA_DEV_ROUTING_MODE=intent
IA_DEV_CAP_ATTENDANCE_ENABLED=0
IA_DEV_CAP_ATTENDANCE_SUMMARY_ENABLED=0
IA_DEV_CAP_ATTENDANCE_TABLE_ENABLED=0
IA_DEV_CAP_ATTENDANCE_RECURRENCE_ENABLED=0
IA_DEV_CAP_ATTENDANCE_ANALYTICS_ENABLED=0
IA_DEV_CAP_TRANSPORT_ENABLED=0
IA_DEV_CAP_TRANSPORT_SUMMARY_ENABLED=0
IA_DEV_CAP_EMPLEADOS_ENABLED=0
IA_DEV_CAP_EMPLEADOS_COUNT_ENABLED=0
IA_DEV_PROACTIVE_LOOP_ENABLED=0
IA_DEV_PROACTIVE_LOOP_MAX_ITERATIONS=2
IA_DEV_DELEGATION_ENABLED=0
IA_DEV_DELEGATION_MODE=off
IA_DEV_DOMAIN_REGISTRY_SYNC_ENABLED=0
IA_DEV_SQL_ASSISTED_ENABLED=0
IA_DEV_DB_READONLY_ALIAS=default
IA_DEV_QUERY_INTELLIGENCE_ENABLED=0
IA_DEV_QUERY_INTELLIGENCE_MODE=shadow
IA_DEV_QUERY_INTELLIGENCE_OPENAI_ENABLED=1
IA_DEV_QUERY_INTENT_MODEL=gpt-5-nano
IA_DEV_QUERY_SQL_ASSISTED_ENABLED=0
IA_DEV_QUERY_SQL_ASSISTED_MAX_LIMIT=500
IA_DEV_QUERY_PATTERN_MEMORY_ENABLED=0
IA_DEV_QUERY_PATTERN_MEMORY_BUSINESS_ENABLED=0
IA_DEV_DOMAIN_ONBOARDING_WORKFLOW_ENABLED=1
IA_DEV_DOMAIN_AUSENTISMO_ENABLED=1
IA_DEV_DOMAIN_EMPLEADOS_ENABLED=1
IA_DEV_DOMAIN_TRANSPORTE_ENABLED=1
IA_DEV_DOMAIN_COMISIONES_ENABLED=1
IA_DEV_DOMAIN_FACTURACION_ENABLED=1
IA_DEV_DOMAIN_VIATICOS_ENABLED=1
IA_DEV_DOMAIN_HORAS_EXTRAS_ENABLED=1

# Policy guard capability runtime
IA_DEV_POLICY_CAPABILITY_EXECUTION_ENABLED=1
IA_DEV_POLICY_ATTENDANCE_PERSONAL_JOIN_ENABLED=1
IA_DEV_POLICY_MEMORY_HINTS_ENABLED=1
IA_DEV_POLICY_ATTENDANCE_FORCE_LEGACY=0
IA_DEV_POLICY_TRANSPORT_FORCE_LEGACY=0

# Policy runtime (PR6)
IA_DEV_POLICY_RUNTIME_ENABLED=1
IA_DEV_POLICY_FAILSAFE_MODE=allow
IA_DEV_POLICY_RUNTIME_CACHE_SECONDS=30

# Workflow state runtime (PR7)
IA_DEV_WORKFLOW_STATE_ENABLED=1
IA_DEV_WORKFLOW_ENFORCE_TRANSITIONS=1

# Observabilidad
IA_DEV_OBSERVABILITY_ENABLED=1
# Ajusta si quieres estimar costo por token para tu modelo real
IA_DEV_OPENAI_INPUT_PRICE_PER_1K=0.00005
IA_DEV_OPENAI_OUTPUT_PRICE_PER_1K=0.00020
