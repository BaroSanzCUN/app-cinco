# ================================================================
# APP CINCO - ENVIRONMENT CONFIGURATION
# ================================================================
# 
# IMPORTANTE - SEGURIDAD:
# 1. Copia este archivo a .env antes de iniciar: cp .env.example .env
# 2. NUNCA subas el archivo .env al repositorio (ya está en .gitignore)
# 3. Genera una SECRET_KEY única usando:
#    python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
# 4. En producción, establece DJANGO_DEBUG=False
# 
# ================================================================

# Django Configuration
# CRÍTICO: Genera una clave única y segura (mínimo 50 caracteres)
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production

# DEBUG: True solo en desarrollo, False en producción
DJANGO_DEBUG=False

# Database Default (db_cincosas)
BD_NAME=db_cincosas
BD_USER=db_user
BD_PASSWORD=secure_password_here
BD_HOST=127.0.0.1
BD_PORT=3306

# Database Azul (cinco-api)
DB_AZUL_NAME=cinco-api
DB_AZUL_USER=db_user
DB_AZUL_PASSWORD=secure_password_here
DB_AZUL_HOST=127.0.0.1
DB_AZUL_PORT=3306

# Paths (para producción en Apache)
BASE_PATH=/home/admcinco/app_cinco/backend/

# Hosts permitidos (separados por coma sin espacios)
ALLOWED_HOSTS=api.cincosas.com,www.api.cincosas.com,192.168.79.11,127.0.0.1,localhost

# IA DEV (Orchestrator + Agent routing)
IA_DEV_MAX_MESSAGES=20
# OpenAI key para clasificador y respuestas generales (usar una sola)
OPENAI_API_KEY=
# Alternativa equivalente si quieres separar config IA_DEV:
IA_DEV_OPENAI_API_KEY=
IA_DEV_USE_OPENAI_CLASSIFIER=1
IA_DEV_INTENT_MODEL=gpt-5-nano
IA_DEV_USE_OPENAI_GENERAL=1
IA_DEV_GENERAL_MODEL=gpt-5-nano
IA_DEV_DB_ALIAS=default
IA_DEV_ATTENDANCE_TABLE=cincosas_cincosas.gestionh_ausentismo
IA_DEV_DICTIONARY_TABLE=ai_dictionary.dd_dominios
IA_DEV_PERSONAL_TABLE=cincosas_cincosas.cinco_base_de_personal
# Dejar vacio si aun no existe fuente de transporte
IA_DEV_TRANSPORT_TABLE=
IA_DEV_TRANSPORT_DATE_COLUMN=fecha_salida
